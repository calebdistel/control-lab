---
import { getCollection } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const TRACK_ORDER = [
    'frc-intro',
    'fundamentals',
    'robot-code',
    'control-systems',
    'software-engineering',
  ];

  const allRaw = await getCollection('lessons', ({ data }) => !data.draft);

  const sorted = [...allRaw].sort((a, b) => {
    const ti = TRACK_ORDER.indexOf(a.data.track);
    const tj = TRACK_ORDER.indexOf(b.data.track);
    if (ti !== tj) return ti - tj;
    return a.data.lesson - b.data.lesson;
  });

  return sorted.map((lesson, i) => {
    const [track, slug] = lesson.slug.split('/');
    return {
      params: { track, slug },
      props: {
        lesson,
        allLessons: sorted,
        prev: i > 0 ? sorted[i - 1] : null,
        next: i < sorted.length - 1 ? sorted[i + 1] : null,
      },
    };
  });
}

const { lesson, allLessons, prev, next } = Astro.props;
const { Content } = await lesson.render();
---
<LessonLayout lesson={lesson} allLessons={allLessons} prev={prev} next={next}>
  <Content />
</LessonLayout>
