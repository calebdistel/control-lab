---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);

const TRACKS = [
  { id: 'summer',          group: 'Summer',       label: 'Foundations',      desc: 'Core programming concepts, control loops, and Java fundamentals.' },
  { id: 'fall',            group: 'Fall',         label: 'Implementation',   desc: 'Subsystems, commands, and building a complete robot program.' },
  { id: 'supplemental-s1', group: 'Supplemental', label: 'Swerve Drive',     desc: 'Kinematics, odometry, and tuning swerve modules.' },
  { id: 'supplemental-s2', group: 'Supplemental', label: 'Vision & Pose',    desc: 'PhotonVision, AprilTags, and field-relative pose estimation.' },
  { id: 'supplemental-s3', group: 'Supplemental', label: 'Auto Routines',    desc: 'PathPlanner, trajectory following, and event markers.' },
  { id: 'supplemental-s4', group: 'Supplemental', label: 'Advanced Control', desc: 'PID tuning, feedforward, and motion profiling.' },
  { id: 'supplemental-s5', group: 'Supplemental', label: 'Tooling',          desc: 'Git, AdvantageScope, logging, and debugging workflows.' },
];

function lessonUrl(l: (typeof allLessons)[number]) {
  const [track, slug] = l.slug.split('/');
  return `/lessons/${track}/${slug}`;
}

const byTrack = Object.fromEntries(
  TRACKS.map(t => [
    t.id,
    allLessons.filter(l => l.data.track === t.id).sort((a, b) => a.data.lesson - b.data.lesson),
  ])
);

const totalLessons = allLessons.length;
const totalTracks = TRACKS.length;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Control Lab — FRC 498</title>
</head>
<body class="index-page">

  <header class="top-nav">
    <div class="top-nav-inner">
      <a href="/" class="brand-link">
        <span class="brand-mark">498</span>
        <div class="brand-text">
          <span class="brand-name">Control Lab</span>
          <span class="brand-sub">FRC Programming Curriculum</span>
        </div>
      </a>
      <div class="top-nav-meta">
        <strong>{totalLessons}</strong> lesson{totalLessons !== 1 ? 's' : ''} · <strong>{totalTracks}</strong> tracks
      </div>
    </div>
  </header>

  <main class="curriculum">

    <section class="hero">
      <p class="hero-eyebrow">FRC 498 · Cobras Programming Team</p>
      <h1 class="hero-title">Master robot software, one lesson at a time.</h1>
      <p class="hero-sub">A self-paced curriculum covering everything from your first program to advanced control systems — built by the team, for the team.</p>
    </section>

    <div class="track-list">
      {TRACKS.map(track => {
        const lessons = byTrack[track.id] ?? [];
        const hasLessons = lessons.length > 0;
        const firstUrl = hasLessons ? lessonUrl(lessons[0]) : null;

        return (
          <section class="track-card">
            <div class="track-header">
              <div class="track-info">
                <p class="track-group">{track.group}</p>
                <h2 class="track-title">{track.label}</h2>
                <p class="track-desc">{track.desc}</p>
              </div>
              <div class="track-actions">
                <span class="track-count">
                  {hasLessons ? `${lessons.length} lesson${lessons.length !== 1 ? 's' : ''}` : 'In progress'}
                </span>
                {firstUrl && (
                  <a href={firstUrl} class="begin-btn">Begin →</a>
                )}
              </div>
            </div>

            {hasLessons && (
              <ul class="lesson-table">
                {lessons.map(l => (
                  <li>
                    <a href={lessonUrl(l)} class="lesson-row">
                      <span class="l-num">{String(l.data.lesson).padStart(2, '0')}</span>
                      <span class="l-title">{l.data.title}</span>
                      <span class="l-dur">{l.data.duration}</span>
                      <span class="l-arrow">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </section>
        );
      })}
    </div>

  </main>

</body>
</html>

<style>
  .curriculum {
    max-width: 920px;
    margin: 0 auto;
    padding: calc(var(--nav-h) + 2rem) 2rem 6rem;
  }

  .hero {
    padding: 1.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .hero-eyebrow {
    font-family: "Audiowide", "Kanit", sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.875rem;
  }
  .hero-title {
    font-family: "Kanit", sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.15;
    max-width: 720px;
    margin-bottom: 0.875rem;
  }
  .hero-sub {
    font-family: "Kanit", sans-serif;
    font-size: 0.95rem;
    color: var(--light-grey);
    max-width: 600px;
    line-height: 1.6;
  }

  .track-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .track-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: border-color 0.18s;
  }
  .track-card:hover { border-color: rgba(77,198,255,0.3); }

  .track-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
  }

  .track-group {
    font-family: "Audiowide", "Kanit", sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.4rem;
  }
  .track-title {
    font-family: "Kanit", sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
    letter-spacing: -0.005em;
  }
  .track-desc {
    font-family: "Kanit", sans-serif;
    font-size: 0.85rem;
    color: var(--light-grey);
    max-width: 500px;
    line-height: 1.55;
  }

  .track-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
    flex-shrink: 0;
    padding-top: 0.25rem;
  }
  .track-count {
    font-family: "Kanit", sans-serif;
    font-size: 0.72rem;
    color: var(--dark-grey);
    letter-spacing: 0.04em;
  }
  .begin-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.45em 1.1em;
    border-radius: var(--r-sm);
    background: var(--accent);
    color: #04141e;
    font-family: "Kanit", sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: background 0.15s, transform 0.1s;
  }
  .begin-btn:hover { background: var(--accent-hover); }
  .begin-btn:active { transform: translateY(1px); }

  .lesson-table {
    border-top: 1px solid var(--border);
    background: rgba(0,0,0,0.3);
  }
  .lesson-table li:not(:last-child) .lesson-row {
    border-bottom: 1px solid var(--border-subtle);
  }

  .lesson-row {
    display: grid;
    grid-template-columns: 2.25rem 1fr auto 1.25rem;
    align-items: center;
    gap: 0.875rem;
    padding: 0.7rem 1.5rem;
    transition: background 0.12s;
  }
  .lesson-row:hover { background: var(--surface-hover); }
  .lesson-row:hover .l-arrow { opacity: 1; color: var(--accent); transform: translateX(2px); }
  .lesson-row:hover .l-title { color: var(--highlight); }

  .l-num {
    font-family: "Audiowide", "Kanit", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--dark-grey);
    text-align: right;
  }
  .l-title {
    font-family: "Kanit", sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
    transition: color 0.12s;
  }
  .l-dur {
    font-family: "Kanit", sans-serif;
    font-size: 0.72rem;
    color: var(--dark-grey);
  }
  .l-arrow {
    font-size: 0.8rem;
    color: var(--dark-grey);
    opacity: 0.5;
    transition: opacity 0.12s, color 0.12s, transform 0.12s;
    text-align: right;
  }
</style>
