---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const allLessons = await getCollection('lessons', ({ data }) => !data.draft);

const TRACKS = [
  { id: 'summer',          group: 'Summer',       label: 'Foundations',      desc: 'Core programming concepts, control loops, and Java fundamentals.' },
  { id: 'fall',            group: 'Fall',         label: 'Implementation',   desc: 'Subsystems, commands, and building a complete robot program.' },
  { id: 'supplemental-s1', group: 'Supplemental', label: 'Swerve Drive',     desc: 'Kinematics, odometry, and tuning swerve modules.' },
  { id: 'supplemental-s2', group: 'Supplemental', label: 'Vision & Pose',    desc: 'PhotonVision, AprilTags, and field-relative pose estimation.' },
  { id: 'supplemental-s3', group: 'Supplemental', label: 'Auto Routines',    desc: 'PathPlanner, trajectory following, and event markers.' },
  { id: 'supplemental-s4', group: 'Supplemental', label: 'Advanced Control', desc: 'PID tuning, feedforward, and motion profiling.' },
  { id: 'supplemental-s5', group: 'Supplemental', label: 'Tooling',          desc: 'Git, AdvantageScope, logging, and debugging workflows.' },
];

function lessonUrl(l: (typeof allLessons)[number]) {
  const [track, slug] = l.slug.split('/');
  return `/lessons/${track}/${slug}`;
}

const byTrack = Object.fromEntries(
  TRACKS.map(t => [
    t.id,
    allLessons.filter(l => l.data.track === t.id).sort((a, b) => a.data.lesson - b.data.lesson),
  ])
);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Control Lab — FRC 498</title>
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <div class="brand">
        <span class="brand-badge">498</span>
        <div>
          <div class="brand-name">Control Lab</div>
          <div class="brand-sub">FRC Programming &amp; Control Systems</div>
        </div>
      </div>
    </div>
  </header>

  <main class="curriculum">
    {TRACKS.map(track => {
      const lessons = byTrack[track.id] ?? [];
      const hasLessons = lessons.length > 0;
      const firstUrl = hasLessons ? lessonUrl(lessons[0]) : null;

      return (
        <section class="track">
          <div class="track-header">
            <div class="track-info">
              <p class="track-group">{track.group}</p>
              <h2 class="track-title">{track.label}</h2>
              <p class="track-desc">{track.desc}</p>
            </div>
            <div class="track-actions">
              {hasLessons && (
                <span class="track-count">{lessons.length} lesson{lessons.length !== 1 ? 's' : ''}</span>
              )}
              {firstUrl && (
                <a href={firstUrl} class="begin-btn">Begin →</a>
              )}
            </div>
          </div>

          {hasLessons ? (
            <ul class="lesson-table">
              {lessons.map(l => (
                <li>
                  <a href={lessonUrl(l)} class="lesson-row">
                    <span class="l-num">{String(l.data.lesson).padStart(2, '0')}</span>
                    <span class="l-title">{l.data.title}</span>
                    <span class="l-dur">{l.data.duration}</span>
                    <span class="l-arrow">→</span>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="coming-soon">Coming soon</p>
          )}
        </section>
      );
    })}
  </main>

</body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.875rem 2rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }
  .brand-badge {
    background: var(--accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 0.3em 0.6em;
    border-radius: 5px;
    flex-shrink: 0;
  }
  .brand-name {
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--text);
  }
  .brand-sub {
    font-size: 0.72rem;
    color: var(--text-subtle);
    margin-top: 0.1rem;
  }

  .curriculum {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 2rem 6rem;
  }

  .track {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
  }
  .track:last-child { border-bottom: none; }

  .track-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.125rem;
  }

  .track-group {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.25rem;
    opacity: 0.8;
  }
  .track-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.375rem;
  }
  .track-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.6;
  }

  .track-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
    padding-top: 0.25rem;
  }
  .track-count {
    font-size: 0.72rem;
    color: var(--text-subtle);
  }
  .begin-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.4em 1em;
    border-radius: var(--r);
    background: var(--accent);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: background 0.15s;
  }
  .begin-btn:hover { background: var(--accent-2); }

  .lesson-table {
    list-style: none;
    border: 1px solid var(--border);
    border-radius: var(--r);
    overflow: hidden;
    background: var(--surface);
  }
  .lesson-table li:not(:last-child) .lesson-row {
    border-bottom: 1px solid var(--border);
  }

  .lesson-row {
    display: grid;
    grid-template-columns: 2rem 1fr auto auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    transition: background 0.1s;
  }
  .lesson-row:hover { background: var(--surface-2); }
  .lesson-row:hover .l-arrow { opacity: 1; color: var(--accent); }

  .l-num {
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-subtle);
    text-align: right;
  }
  .l-title {
    font-size: 0.875rem;
    color: var(--text);
    font-weight: 500;
  }
  .l-dur {
    font-size: 0.72rem;
    color: var(--text-subtle);
  }
  .l-arrow {
    font-size: 0.75rem;
    color: var(--text-subtle);
    opacity: 0;
    transition: opacity 0.1s, color 0.1s;
  }

  .coming-soon {
    font-size: 0.82rem;
    color: var(--text-subtle);
    font-style: italic;
  }
</style>
