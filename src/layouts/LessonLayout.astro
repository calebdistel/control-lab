---
import type { CollectionEntry } from 'astro:content';
import '../styles/global.css';

type Props = {
  lesson: CollectionEntry<'lessons'>;
  allLessons: CollectionEntry<'lessons'>[];
  prev: CollectionEntry<'lessons'> | null;
  next: CollectionEntry<'lessons'> | null;
};

const { lesson, allLessons, prev, next } = Astro.props;
const { data } = lesson;

const TRACKS = [
  { id: 'summer',          label: 'Foundations',      group: 'Summer' },
  { id: 'fall',            label: 'Implementation',   group: 'Fall' },
  { id: 'supplemental-s1', label: 'Swerve Drive',     group: 'Supplemental' },
  { id: 'supplemental-s2', label: 'Vision & Pose',    group: 'Supplemental' },
  { id: 'supplemental-s3', label: 'Auto Routines',    group: 'Supplemental' },
  { id: 'supplemental-s4', label: 'Advanced Control', group: 'Supplemental' },
  { id: 'supplemental-s5', label: 'Tooling',          group: 'Supplemental' },
];

function lessonUrl(l: CollectionEntry<'lessons'>) {
  const [track, slug] = l.slug.split('/');
  return `/lessons/${track}/${slug}`;
}

const byTrack = Object.fromEntries(
  TRACKS.map(t => [t.id, allLessons.filter(l => l.data.track === t.id)])
);

const currentTrack = TRACKS.find(t => t.id === data.track)!;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{data.title} — Control Lab</title>
</head>
<body class="lesson-page">

  <header class="top-nav">
    <div class="top-nav-inner">
      <a href="/" class="brand-link">
        <span class="brand-mark">498</span>
        <div class="brand-text">
          <span class="brand-name">Control Lab</span>
          <span class="brand-sub">FRC Programming Curriculum</span>
        </div>
      </a>
      <div class="top-nav-meta">
        <strong>{currentTrack.group}</strong> · {currentTrack.label} · L{String(data.lesson).padStart(2, '0')}
      </div>
    </div>
  </header>

  <aside class="sidebar">
    <nav class="sidebar-nav">
      {TRACKS.map(track => {
        const lessons = byTrack[track.id];
        if (!lessons || lessons.length === 0) return null;
        const isCurrentTrack = track.id === data.track;
        return (
          <div class={`track-group${isCurrentTrack ? ' is-active' : ''}`}>
            <div class="track-label">
              <span class="track-group-name">{track.group}</span>
              <span class="track-sub-name">{track.label}</span>
            </div>
            <ul class="lesson-list">
              {lessons.map(l => {
                const active = l.slug === lesson.slug;
                return (
                  <li>
                    <a href={lessonUrl(l)} class={`lesson-item${active ? ' is-active' : ''}`}>
                      <span class="lesson-num">{String(l.data.lesson).padStart(2, '0')}</span>
                      <span class="lesson-name">{l.data.title}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })}
    </nav>
  </aside>

  <main class="main">
    <div class="lesson-wrap">

      <header class="lesson-head">
        <p class="breadcrumb">
          <span>{currentTrack.group}</span>
          <span class="bc-sep">›</span>
          <span>{currentTrack.label}</span>
          <span class="bc-sep">›</span>
          <span>Lesson {String(data.lesson).padStart(2, '0')}</span>
        </p>
        <h1>{data.title}</h1>
        <div class="meta-row">
          <span class="badge">{data.duration}</span>
          {data.prereqs.length > 0 && (
            <span class="badge badge-muted">Prereqs: {data.prereqs.join(', ')}</span>
          )}
          <span class="badge badge-muted">{data.contributedBy}</span>
        </div>
        {data.objectives.length > 0 && (
          <details class="objectives">
            <summary>Learning objectives</summary>
            <ul>
              {data.objectives.map(o => <li>{o}</li>)}
            </ul>
          </details>
        )}
      </header>

      <div class="lesson-body">
        <slot />
      </div>

      <footer class="lesson-foot">
        <div class="nav-pair">
          {prev ? (
            <a href={lessonUrl(prev)} class="nav-card">
              <span class="nav-dir">← Previous</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          ) : <span />}
          {next ? (
            <a href={lessonUrl(next)} class="nav-card nav-card-next">
              <span class="nav-dir">Next →</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          ) : <span />}
        </div>
      </footer>

    </div>
  </main>

</body>
</html>

<style is:global>

/* ── Sidebar ─────────────────────────────────── */

.sidebar {
  position: fixed;
  top: var(--nav-h);
  left: 0;
  bottom: 0;
  width: var(--sidebar-w);
  background: rgba(0,0,0,0.6);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  z-index: 20;
}

.sidebar-nav {
  padding: 1.25rem 0 2rem;
}

.track-group { margin-bottom: 0.75rem; }

.track-label {
  padding: 0.5rem 1.25rem 0.375rem;
  display: flex;
  flex-direction: column;
}
.track-group-name {
  font-family: "Audiowide", "Kanit", sans-serif;
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--dark-grey);
}
.track-group.is-active .track-group-name { color: var(--accent); }
.track-sub-name {
  font-family: "Kanit", sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--light-grey);
  margin-top: 0.15rem;
  letter-spacing: 0.01em;
}

.lesson-list { padding: 0; }

.lesson-item {
  display: flex;
  align-items: baseline;
  gap: 0.625rem;
  padding: 0.4rem 1.25rem;
  font-family: "Kanit", sans-serif;
  font-size: 0.82rem;
  font-weight: 400;
  color: var(--light-grey);
  border-left: 3px solid transparent;
  transition: background 0.12s ease, color 0.12s ease, border-color 0.12s ease;
  line-height: 1.4;
}
.lesson-item:hover {
  background: var(--surface-hover);
  color: var(--highlight);
}
.lesson-item.is-active {
  background: var(--accent-dim);
  color: var(--accent);
  border-left-color: var(--accent);
  font-weight: 600;
}
.lesson-num {
  font-family: "Audiowide", "Kanit", monospace;
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  color: var(--dark-grey);
  min-width: 1.5rem;
  flex-shrink: 0;
}
.lesson-item.is-active .lesson-num { color: var(--accent); }
.lesson-name { line-height: 1.4; }

/* ── Main layout ─────────────────────────────── */

.main {
  margin-left: var(--sidebar-w);
  margin-top: var(--nav-h);
  min-height: calc(100vh - var(--nav-h));
  display: flex;
  justify-content: center;
}

.lesson-wrap {
  width: 100%;
  max-width: var(--content-w);
  padding: 2.5rem 2.5rem 6rem;
}

/* ── Lesson header ───────────────────────────── */

.lesson-head { margin-bottom: 2.75rem; }

.breadcrumb {
  font-family: "Kanit", sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent);
  margin-bottom: 0.85rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-wrap: wrap;
}
.bc-sep { color: var(--dark-grey); }

.lesson-head h1 {
  font-family: "Kanit", sans-serif;
  font-size: 2.125rem;
  font-weight: 700;
  letter-spacing: -0.015em;
  color: var(--text);
  line-height: 1.15;
  margin-bottom: 1rem;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.3em 0.75em;
  border-radius: var(--r-sm);
  font-family: "Kanit", sans-serif;
  font-size: 0.72rem;
  font-weight: 600;
  background: var(--accent-dim);
  color: var(--accent);
  border: 1px solid rgba(77,198,255,0.3);
  letter-spacing: 0.02em;
}
.badge-muted {
  background: var(--surface);
  color: var(--light-grey);
  border-color: var(--border);
}

.objectives {
  border: 1px solid var(--border);
  border-radius: var(--r);
  background: var(--surface);
  overflow: hidden;
  transition: border-color 0.15s;
}
.objectives[open] { border-color: rgba(77,198,255,0.3); }
.objectives summary {
  padding: 0.7rem 1rem;
  font-family: "Kanit", sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--light-grey);
  cursor: pointer;
  user-select: none;
  list-style: none;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  transition: color 0.12s;
}
.objectives summary:hover { color: var(--highlight); }
.objectives summary::before {
  content: '▶';
  font-size: 0.55rem;
  color: var(--accent);
  transition: transform 0.18s ease;
}
.objectives[open] summary::before { transform: rotate(90deg); }
.objectives ul {
  padding: 0.25rem 1rem 0.875rem 2.25rem;
  list-style: disc;
}
.objectives li {
  font-size: 0.85rem;
  color: var(--light-grey);
  padding: 0.2rem 0;
  line-height: 1.55;
  list-style: disc;
}

/* ── Prose / lesson body ─────────────────────── */

.lesson-body { font-family: "Kanit", sans-serif; font-weight: 400; }
.lesson-body > * + * { margin-top: 1.25rem; }

.lesson-body h2 {
  font-family: "Kanit", sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--text);
  padding-top: 2.5rem;
  margin-top: 2.5rem !important;
  padding-bottom: 0.65rem;
  border-bottom: 1px solid var(--border);
}
.lesson-body h2:first-child { padding-top: 0; margin-top: 0 !important; }

.lesson-body h3 {
  font-family: "Kanit", sans-serif;
  font-size: 1.075rem;
  font-weight: 600;
  color: var(--text);
  margin-top: 2rem !important;
}

.lesson-body h4 {
  font-family: "Audiowide", "Kanit", sans-serif;
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  margin-top: 1.5rem !important;
}

.lesson-body p {
  color: var(--light-grey);
  line-height: 1.8;
}

.lesson-body strong { color: var(--text); font-weight: 600; }
.lesson-body em { color: var(--highlight); font-style: italic; }

.lesson-body a {
  color: var(--accent);
  border-bottom: 1px solid rgba(77,198,255,0.3);
  transition: border-color 0.15s, color 0.15s;
}
.lesson-body a:hover {
  color: var(--accent-hover);
  border-bottom-color: var(--accent);
}

.lesson-body ul,
.lesson-body ol {
  padding-left: 1.625rem;
  color: var(--light-grey);
}
.lesson-body ul li,
.lesson-body ol li {
  padding: 0.2rem 0;
  line-height: 1.75;
  list-style: disc;
}
.lesson-body ol li { list-style: decimal; }
.lesson-body li + li { margin-top: 0.1rem; }

.lesson-body blockquote {
  border-left: 3px solid var(--accent);
  padding: 0.875rem 1.25rem;
  background: var(--accent-dim);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
}
.lesson-body blockquote p {
  color: var(--light-grey);
  font-style: italic;
  margin: 0;
}

/* Shiki-styled code blocks */
.lesson-body pre {
  border-radius: var(--r);
  padding: 1.125rem 1.375rem;
  overflow-x: auto;
  border: 1px solid var(--border);
  background: var(--surface) !important;
  margin: 1.75rem 0;
  font-size: 0.86rem;
  line-height: 1.65;
  font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
}

.lesson-body code:not(pre > code) {
  font-family: ui-monospace, "Cascadia Code", "Source Code Pro", Menlo, Consolas, monospace;
  font-size: 0.86em;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 0.15em 0.45em;
  color: var(--highlight);
}

/* ── Prev / next nav ─────────────────────────── */

.lesson-foot {
  margin-top: 4rem;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}

.nav-pair {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.875rem;
}

.nav-card {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding: 1.1rem 1.3rem;
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  background: var(--surface);
  transition: border-color 0.18s, background 0.18s, transform 0.12s;
}
.nav-card:hover {
  border-color: var(--accent);
  background: var(--surface-hover);
  transform: translateY(-1px);
}
.nav-card-next { text-align: right; }

.nav-dir {
  font-family: "Audiowide", "Kanit", sans-serif;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--dark-grey);
  transition: color 0.15s;
}
.nav-card:hover .nav-dir { color: var(--accent); }
.nav-title {
  font-family: "Kanit", sans-serif;
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--text);
  line-height: 1.4;
}

</style>
